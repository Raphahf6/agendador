{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "images": {
    "localPatterns": [],
    "remotePatterns": []
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/router?path=:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
